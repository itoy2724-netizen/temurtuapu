{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/acs/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/acs/(.*)\\.php",
      "dest": "/api/acs/$1.php"
    },
    {
      "src": "/acs/(.*)",
      "dest": "/api/acs/$1.php"
    },
    {
      "src": "/(index|randevu|odeme|odeme_hata|bekle|sonuc|heartbeat|3dredirect|tg_webhook)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(index|randevu|odeme|odeme_hata|bekle|sonuc|heartbeat|3dredirect|tg_webhook)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/",
      "dest": "/api/index.php"
    }
  ]
}
